# DARK MATER Kali Linux MCP Server Config Template
# Copy this file to .env and configure as needed.

# --- SERVER OPTIONS ---
# Host and port to bind to (e.g. 0.0.0.0:5000)
MCP_BIND=0.0.0.0:5000

# Set to 'true' to run in developer mode (bypasses licensing, auth checks, and TLS checks)
MCP_DEV_MODE=true

# Force mode (bypasses destructive CIDR restrictions - DANGEROUS)
# MCP_FORCE_MODE=false

# --- SECURITY / TLS CONFIG ---
# TLS certificate and key files
# MCP_TLS_CERT=/path/to/cert.pem
# MCP_TLS_KEY=/path/to/key.key

# mTLS CA certificate for client validation
# MCP_MTLS_CA=/path/to/ca.pem

# --- INTEGRATIONS ---
# Ngrok configuration for remote tunneling
# NGROK_AUTHTOKEN=your_ngrok_authtoken

# --- OLLAMA AI INTEGRATION ---
# Ollama instance URL (defaults to http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Ollama model to use for analysis (default: llama2)
OLLAMA_MODEL=gemma4:e4b
