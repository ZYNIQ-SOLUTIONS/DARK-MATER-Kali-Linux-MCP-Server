{
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "title":  "net.traceroute",
    "description":  "Perform a network traceroute to the target",
    "type":  "object",
    "properties":  {
                       "protocol":  {
                                        "enum":  [
                                                     "icmp",
                                                     "tcp",
                                                     "udp"
                                                 ],
                                        "default":  "icmp",
                                        "description":  "Protocol to use",
                                        "type":  "string"
                                    },
                       "max_hops":  {
                                        "default":  30,
                                        "maximum":  64,
                                        "description":  "Maximum hops",
                                        "type":  "integer",
                                        "minimum":  1
                                    },
                       "target":  {
                                      "pattern":  "^[0-9A-Za-z.:/_-]+$",
                                      "description":  "Target IP or hostname",
                                      "type":  "string"
                                  }
                   },
    "required":  [
                     "target"
                 ],
    "additionalProperties":  false
}