{
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "title":  "enum.ldap",
    "description":  "LDAP directory enumeration using ldap-utils",
    "type":  "object",
    "properties":  {
                       "port":  {
                                    "default":  389,
                                    "maximum":  65535,
                                    "description":  "LDAP port",
                                    "type":  "integer",
                                    "minimum":  1
                                },
                       "base_dn":  {
                                       "type":  "string",
                                       "description":  "Base DN for search (optional, auto-detected)"
                                   },
                       "target":  {
                                      "pattern":  "^[0-9A-Za-z.:/_-]+$",
                                      "description":  "Target IP or hostname",
                                      "type":  "string"
                                  }
                   },
    "required":  [
                     "target"
                 ],
    "additionalProperties":  false
}