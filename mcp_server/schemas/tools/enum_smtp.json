{
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "title":  "enum.smtp",
    "description":  "SMTP service enumeration - banner, VRFY/EXPN user enumeration",
    "type":  "object",
    "properties":  {
                       "port":  {
                                    "default":  25,
                                    "maximum":  65535,
                                    "description":  "SMTP port",
                                    "type":  "integer",
                                    "minimum":  1
                                },
                       "users":  {
                                     "description":  "Comma-separated usernames to test via VRFY",
                                     "default":  "admin,root,test",
                                     "type":  "string"
                                 },
                       "target":  {
                                      "pattern":  "^[0-9A-Za-z.:/_-]+$",
                                      "description":  "Target IP or hostname",
                                      "type":  "string"
                                  }
                   },
    "required":  [
                     "target"
                 ],
    "additionalProperties":  false
}