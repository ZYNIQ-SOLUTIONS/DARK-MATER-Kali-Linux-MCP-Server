{
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "title":  "enum.ftp",
    "description":  "FTP service enumeration - banner grab, anonymous login check",
    "type":  "object",
    "properties":  {
                       "target":  {
                                      "pattern":  "^[0-9A-Za-z.:/_-]+$",
                                      "description":  "Target IP or hostname",
                                      "type":  "string"
                                  },
                       "port":  {
                                    "default":  21,
                                    "maximum":  65535,
                                    "description":  "FTP port",
                                    "type":  "integer",
                                    "minimum":  1
                                }
                   },
    "required":  [
                     "target"
                 ],
    "additionalProperties":  false
}