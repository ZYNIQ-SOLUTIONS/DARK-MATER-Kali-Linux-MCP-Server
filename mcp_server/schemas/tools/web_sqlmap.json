{
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "title":  "web.sqlmap",
    "description":  "Automated SQL injection testing using sqlmap",
    "type":  "object",
    "properties":  {
                       "risk":  {
                                    "default":  1,
                                    "maximum":  3,
                                    "description":  "Risk of tests (1-3)",
                                    "type":  "integer",
                                    "minimum":  1
                                },
                       "dbs":  {
                                   "description":  "Enumerate databases on success",
                                   "default":  false,
                                   "type":  "boolean"
                               },
                       "data":  {
                                    "type":  "string",
                                    "description":  "POST data string (for POST-based injection)"
                                },
                       "target":  {
                                      "pattern":  "^https?://[a-zA-Z0-9._-]+.*$",
                                      "description":  "Target URL to test",
                                      "type":  "string"
                                  },
                       "level":  {
                                     "default":  1,
                                     "maximum":  5,
                                     "description":  "Tests level (1-5)",
                                     "type":  "integer",
                                     "minimum":  1
                                 }
                   },
    "required":  [
                     "target"
                 ],
    "additionalProperties":  false
}